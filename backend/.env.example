# ═════════════════════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT ENVIRONMENT CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values for your local setup

# Server Port (default: 5000)
PORT=5000

# Environment Mode (development|production)
NODE_ENV=development

# MongoDB Connection (local MongoDB)
MONGO_URI=mongodb://127.0.0.1:27017/myfashion

# JWT Secret (change this in production)
JWT_SECRET=your-secret-key-change-this-in-production

# Frontend URL (for CORS in local development)
CLIENT_URL=http://localhost:3000

# Google OAuth (optional - for Google login feature)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Razorpay Payment Gateway (optional - for payment feature)
RAZORPAY_KEY_ID=rzp_live_SgBj7efTe8bW2C
RAZORPAY_KEY_SECRET=ZS69i7GHCqPEK5eBKOu9sHqT

# File Upload Settings
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp
